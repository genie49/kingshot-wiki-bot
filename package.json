{
  "name": "kingshot-wiki-bot",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "build": "npm run build:api && npm run build:web",
    "build:api": "npm --workspace apps/api run build",
    "build:web": "npm --workspace apps/web run build",
    "start:api": "npm --workspace apps/api run start",
    "start:web": "npm --workspace apps/web run start",
    "typecheck": "npm --workspace apps/api run typecheck && npm --workspace apps/web run typecheck"
  },
  "overrides": {
    "@langchain/core": "^1.1.44"
  }
}
