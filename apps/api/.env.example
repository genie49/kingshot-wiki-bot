PORT=8000
CORS_ORIGIN=http://localhost:5173

SUPABASE_URL=
SUPABASE_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=

GCS_BUCKET=
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS_JSON=
GCS_PUBLIC_BASE_URL=

# Embeddings still use Gemini (OpenRouter does not host the embedding model used here)
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIMENSIONS=1536

# Chat / generation runs on OpenRouter (DeepSeek V4 Pro)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_GENERATION_MODEL=deepseek/deepseek-v4-pro
OPENROUTER_HTTP_REFERER=https://kingshot-wiki-bot.local
OPENROUTER_APP_TITLE=Kingshot Wiki Bot

RAG_MIN_SIMILARITY=0.55
